{
  "name": "gitnote-quick",
  "version": "1.1.0",
  "description": "A lightweight clipboard note app with GitHub sync.",
  "main": "src/main.js",
  "author": "GitNote",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "build:linux": "electron-builder --linux",
    "build:all": "electron-builder -mwl"
  },
  "dependencies": {
    "electron-store": "^8.2.0",
    "simple-git": "^3.30.0"
  },
  "devDependencies": {
    "electron": "^36.3.2",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.gitnote.quick",
    "productName": "GitNote Quick",
    "files": [
      "src/**/*",
      "package.json"
    ],
    "icon": "src/icon",
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "artifactName": "${productName}-${version}-mac-Install.dmg"
    },
    "dmg": {
      "artifactName": "${productName}-${version}-mac-Install.dmg"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "artifactName": "${productName}-${version}-win-Install.exe"
    },
    "portable": {
      "artifactName": "${productName}-${version}-win-Portable.exe"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Utility"
    },
    "appImage": {
      "artifactName": "${productName}-${version}-linux-Portable.${ext}"
    },
    "deb": {
      "maintainer": "GitNote <contact@catvinci.com>",
      "artifactName": "${productName}-${version}-linux-Install.${ext}"
    },
    "publish": null
  }
}
